#!/usr/bin/env python
"""
Identify solo LTR retrotransposons from DANTE_LTR output.

Workflow:
  1. Build LTR reference library and junction tag databases (once, full genome).
  2. Split large genomes into overlapping chunks.
  3. Run BLAST + TSD/junction validation on each chunk.
  4. Merge chunk outputs, remap coordinates, write final GFF3 and statistics.
"""

import argparse
import os
import shutil
import sys
import tempfile
from itertools import cycle
import subprocess

# Reuse chunking / GFF3 utilities from dante_ltr
import importlib.util

def _load_dante_ltr():
    import importlib.machinery
    path   = os.path.join(os.path.dirname(os.path.realpath(__file__)), "dante_ltr")
    loader = importlib.machinery.SourceFileLoader("dante_ltr_mod", path)
    spec   = importlib.util.spec_from_loader("dante_ltr_mod", loader)
    mod    = importlib.util.module_from_spec(spec)
    loader.exec_module(mod)
    return mod

_dl = _load_dante_ltr()

read_fasta_sequence_size                    = _dl.read_fasta_sequence_size
make_temp_files                             = _dl.make_temp_files
split_fasta_to_chunks                       = _dl.split_fasta_to_chunks
recalculate_gff3_coordinates                = _dl.recalculate_gff3_coordinates
recalculate_gff3_back_to_original_coordinates = _dl.recalculate_gff3_back_to_original_coordinates
get_unique_features                         = _dl.get_unique_features
filter_gff3_file                            = _dl.filter_gff3_file
add_version_to_gff3                         = _dl.add_version_to_gff3
verify_seqnames                             = _dl.verify_seqnames
Gff3Feature                                 = _dl.Gff3Feature

from version import __version__


def get_arguments():
    parser = argparse.ArgumentParser(
        description="Identify solo LTR retrotransposons from DANTE_LTR output",
        formatter_class=argparse.RawTextHelpFormatter
    )
    parser.add_argument('-g', '--gff3', required=True,
                        help='DANTE_LTR GFF3 annotation file')
    parser.add_argument('-s', '--reference_sequence', required=True,
                        help='Reference genome FASTA')
    parser.add_argument('-o', '--output', required=True,
                        help='Output file prefix')
    parser.add_argument('-c', '--cpu', default=1, type=int,
                        help='Number of CPUs (default: %(default)s)')
    parser.add_argument('-i', '--min_identity', default=80, type=float,
                        help='Minimum BLAST identity %% (default: %(default)s)')
    parser.add_argument('-C', '--min_coverage', default=0.8, type=float,
                        help='Minimum alignment coverage of query LTR (default: %(default)s)')
    parser.add_argument('-S', '--max_chunk_size', default=100_000_000, type=int,
                        help='Max genome chunk size in bp (default: %(default)s)')
    parser.add_argument('-v', '--version', action='version',
                        version='%(prog)s ' + __version__)
    return parser.parse_args()


def merge_solo_stats(files):
    """
    Merge per-chunk statistics CSVs.
    Columns: Classification, SL, SL_noTSD, Complete_elements, Rsf
    SL / SL_noTSD / Complete_elements are summed; Rsf is recomputed.
    """
    merged = {}   # lineage -> [SL, SL_noTSD, Complete_elements]
    for f in files:
        if not os.path.exists(f) or os.path.getsize(f) == 0:
            continue
        with open(f) as fh:
            for line in fh:
                parts = line.strip().split('\t')
                if parts[0] == 'Classification':
                    continue
                if len(parts) < 4:
                    continue
                lin = parts[0]
                try:
                    vals = [int(parts[1]), int(parts[2]), int(parts[3])]
                except ValueError:
                    continue
                if lin in merged:
                    merged[lin] = [a + b for a, b in zip(merged[lin], vals)]
                else:
                    merged[lin] = vals

    lines = ['Classification\tSL\tSL_noTSD\tComplete_elements\tRsf']
    for lin in sorted(merged):
        sl, sl_no, comp = merged[lin]
        rsf = f'{sl / comp:.3f}' if comp > 0 else 'NA'
        lines.append(f'{lin}\t{sl}\t{sl_no}\t{comp}\t{rsf}')
    return lines


def main():
    args = get_arguments()
    tool_path = os.path.dirname(os.path.realpath(__file__))

    print("--------------------------------------------------------")
    print("")
    print("      ---|>>>>>---- DANTE_LTR solo ---->>>>>|---")
    print("")
    print("     Solo LTR identification from DANTE_LTR output")
    print("")
    print("--------------------------------------------------------")

    if not verify_seqnames(args.gff3, args.reference_sequence):
        sys.stderr.write(
            'ERROR: No sequence names in GFF3 match the reference FASTA.\n'
            'Ensure the GFF3 was produced from the same reference.\n'
        )
        sys.exit(1)

    tmpdir = tempfile.mkdtemp(prefix='dante_ltr_solo_')
    try:
        _run(args, tool_path, tmpdir)
    finally:
        shutil.rmtree(tmpdir, ignore_errors=True)


def _run(args, tool_path, tmpdir):
    # ------------------------------------------------------------------ #
    # Step 1 – Build LTR library (once, on the full genome + full GFF3)   #
    # ------------------------------------------------------------------ #
    lib_prefix = os.path.join(tmpdir, 'ltr_lib')
    print('Building LTR reference library ...')
    subprocess.check_call([
        f'{tool_path}/utils/build_ltr_library.R',
        '-g', args.gff3,
        '-s', args.reference_sequence,
        '-o', lib_prefix,
        '-t', str(args.cpu),
    ])

    ltr_library = f'{lib_prefix}_LTR_library.fasta'
    ltr_map     = f'{lib_prefix}_LTR_library_map.tsv'
    utr5_db     = f'{lib_prefix}_5UTR_tags.fasta'
    ppt_db      = f'{lib_prefix}_PPT_tags.fasta'
    tsd_map     = f'{lib_prefix}_tsd_length_map.tsv'

    if not os.path.exists(ltr_library) or os.path.getsize(ltr_library) == 0:
        sys.stderr.write('ERROR: LTR library is empty. '
                         'Ensure the input GFF3 contains DL or higher rank elements.\n')
        sys.exit(1)

    # tRNA database for PBS check
    trna_db = os.path.join(
        tool_path,
        'databases',
        'tRNAscan-SE_ALL_spliced-yes_2022-12-14_plus-old-tRNAs_UC_unique-3ends.fasta'
    )

    # ------------------------------------------------------------------ #
    # Step 2 – Chunk genome + GFF3                                        #
    # ------------------------------------------------------------------ #
    fasta_seq_sizes = read_fasta_sequence_size(args.reference_sequence)
    total_size      = sum(fasta_seq_sizes.values())
    n_seqs          = len(fasta_seq_sizes)

    fasta_split, matching_table = split_fasta_to_chunks(
        args.reference_sequence, chunk_size=args.max_chunk_size
    )
    gff3_remapped = recalculate_gff3_coordinates(args.gff3, matching_table)

    split_sizes = read_fasta_sequence_size(fasta_split)

    if total_size > args.max_chunk_size and n_seqs > 1:
        print(f'Running analysis in chunks of ~{args.max_chunk_size:,} bp')

        seq_sorted = [k for k, _ in sorted(split_sizes.items(),
                                           key=lambda x: x[1], reverse=True)]
        n_chunks = min(int(total_size / args.max_chunk_size) + 1, n_seqs)

        # Distribute sequences round-robin across chunk files
        tmp_fasta = make_temp_files(n_chunks)
        tmp_gff   = make_temp_files(n_chunks)
        fh_fasta  = [open(f, 'w') for f in tmp_fasta]
        seq_to_fh = dict(zip(seq_sorted, cycle(fh_fasta)))

        with open(fasta_split) as f:
            header = None
            for line in f:
                if line[0] == '>':
                    header = line.strip().split()[0][1:]
                seq_to_fh[header].write(line)
        for fh in fh_fasta:
            fh.close()
        os.remove(fasta_split)

        fh_gff = [open(f, 'w') for f in tmp_gff]
        seq_to_gff = dict(zip(seq_sorted, cycle(fh_gff)))
        with open(gff3_remapped) as f:
            for line in f:
                if line[0] == '#':
                    continue
                header = line.split('\t')[0]
                if header in seq_to_gff:
                    seq_to_gff[header].write(line)
        for fh in fh_gff:
            fh.close()
        os.remove(gff3_remapped)

        # Per-chunk detection
        tmp_out = make_temp_files(n_chunks)
        for i in range(n_chunks):
            print(f'  Processing chunk {i + 1}/{n_chunks} ...')
            _run_detect_chunk(
                tool_path, tmp_fasta[i], tmp_gff[i],
                ltr_library, ltr_map, utr5_db, ppt_db, tsd_map, trna_db,
                tmp_out[i], args
            )

        # Clean up input temporaries
        for f in tmp_fasta + tmp_gff:
            try:
                os.remove(f)
            except FileNotFoundError:
                pass

        # Merge GFF3 outputs (with coordinate remapping back to original)
        tmp_merged_gff = tempfile.NamedTemporaryFile(delete=False, suffix='.gff3').name
        with open(tmp_merged_gff, 'w') as fout:
            for i in range(n_chunks):
                chunk_gff = tmp_out[i] + '.gff3'
                if not os.path.exists(chunk_gff) or os.path.getsize(chunk_gff) == 0:
                    continue
                remapped = recalculate_gff3_back_to_original_coordinates(
                    chunk_gff, matching_table
                )
                with open(remapped) as fin:
                    for line in fin:
                        fout.write(line)
                os.remove(remapped)
                os.remove(chunk_gff)

        # Deduplicate solo_LTR features at chunk boundaries
        good_ids = get_unique_features(tmp_merged_gff)
        filter_gff3_file(tmp_merged_gff, good_ids, args.output + '.gff3')
        os.remove(tmp_merged_gff)

        # Merge statistics
        stat_files = [f + '_statistics.csv' for f in tmp_out]
        merged_stats = merge_solo_stats(stat_files)
        with open(args.output + '_statistics.csv', 'w') as fout:
            fout.write('\n'.join(merged_stats))
        for f in stat_files:
            try:
                os.remove(f)
            except FileNotFoundError:
                pass

    else:
        # Small genome – run directly without chunking
        print('Running analysis on full genome (no chunking needed)')
        os.remove(fasta_split)
        _run_detect_chunk(
            tool_path, args.reference_sequence, gff3_remapped,
            ltr_library, ltr_map, utr5_db, ppt_db, tsd_map, trna_db,
            args.output, args
        )
        os.remove(gff3_remapped)

    # Add version header to output GFF3
    if os.path.exists(args.output + '.gff3') and os.path.getsize(args.output + '.gff3') > 0:
        add_version_to_gff3(args.output + '.gff3', __version__)

    print(f'Done. Output: {args.output}.gff3')


def _run_detect_chunk(tool_path, fasta, gff3, ltr_library, ltr_map,
                      utr5_db, ppt_db, tsd_map, trna_db, output, args):
    """Run detect_solo_ltr.R for one genome chunk."""
    cmd = [
        f'{tool_path}/utils/detect_solo_ltr.R',
        '-s', fasta,
        '-g', gff3,
        '-l', ltr_library,
        '-M', ltr_map,
        '-u', utr5_db,
        '-p', ppt_db,
        '-m', tsd_map,
        '-o', output,
        '-c', str(args.cpu),
        '-i', str(args.min_identity),
        '-C', str(args.min_coverage),
    ]
    if trna_db and os.path.exists(trna_db + '.nin'):
        cmd += ['-T', trna_db]
    subprocess.check_call(cmd)


if __name__ == '__main__':
    if sys.version_info < (3, 6):
        print('Python 3.6 or greater is required')
        sys.exit(1)
    main()
